---
interface Props {
  title: string;
  date: Date;
  category: 'News' | 'Knowledge' | 'Analysis';
  summary: string;
  slug: string;
  thumbnail?: string;
}

const { title, date, category, summary, slug, thumbnail } = Astro.props;

const categoryColors: Record<string, string> = {
  News: 'bg-badge-news/20 text-badge-news',
  Knowledge: 'bg-badge-knowledge/20 text-badge-knowledge',
  Analysis: 'bg-badge-analysis/20 text-badge-analysis',
};

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a href={`/blog/${slug}`} class="group block">
  <article class="overflow-hidden rounded-xl border border-white/5 bg-bg-secondary transition-all duration-300 hover:border-accent/30 hover:shadow-lg hover:shadow-accent/5">
    <!-- Thumbnail -->
    <div class="aspect-video w-full bg-bg-tertiary">
      {thumbnail ? (
        <img src={thumbnail} alt={title} class="h-full w-full object-cover" />
      ) : (
        <div class="flex h-full w-full items-center justify-center">
          <svg class="h-12 w-12 text-text-secondary/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z" />
          </svg>
        </div>
      )}
    </div>

    <!-- Content -->
    <div class="p-5">
      <div class="mb-3 flex items-center gap-3">
        <span class={`inline-block rounded-full px-3 py-0.5 text-xs font-semibold ${categoryColors[category]}`}>
          {category}
        </span>
        <span class="text-xs text-text-secondary">{formattedDate}</span>
      </div>

      <h3 class="mb-2 text-lg font-semibold leading-snug text-text-primary transition-colors group-hover:text-accent">
        {title}
      </h3>

      <p class="line-clamp-2 text-sm leading-relaxed text-text-secondary">
        {summary}
      </p>
    </div>
  </article>
</a>
