---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/category/news', label: 'News' },
  { href: '/category/knowledge', label: 'Knowledge' },
  { href: '/category/analysis', label: 'Analysis' },
  { href: '/about', label: 'About' },
];
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-bg-primary/80 backdrop-blur-xl">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 sm:px-6">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 text-xl font-bold tracking-tight">
      <span class="text-accent">Crypto</span><span class="text-text-primary">Vibe</span>
    </a>

    <!-- Desktop Nav -->
    <ul class="hidden gap-8 md:flex">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="text-sm font-medium text-text-secondary transition-colors hover:text-accent"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile Menu Toggle (checkbox hack) -->
    <label for="mobile-menu-toggle" class="cursor-pointer md:hidden">
      <svg class="h-6 w-6 text-text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </label>
    <input type="checkbox" id="mobile-menu-toggle" class="peer hidden" />

    <!-- Mobile Menu -->
    <div class="fixed inset-0 top-[65px] z-40 hidden bg-bg-primary/95 backdrop-blur-xl peer-checked:block md:hidden">
      <ul class="flex flex-col items-center gap-6 pt-12">
        {navLinks.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class="text-lg font-medium text-text-secondary transition-colors hover:text-accent"
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>
</header>
