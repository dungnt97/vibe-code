---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const categories = ['News', 'Knowledge', 'Analysis'] as const;
  return categories.map((category) => ({
    params: { category: category.toLowerCase() },
    props: { category },
  }));
}

interface Props {
  category: 'News' | 'Knowledge' | 'Analysis';
}

const { category } = Astro.props;

const allPosts = await getCollection('blog');
const filteredPosts = allPosts
  .filter((post) => post.data.category === category)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const categoryDescriptions: Record<string, string> = {
  News: 'Breaking cryptocurrency news and market updates.',
  Knowledge: 'Educational content to deepen your crypto understanding.',
  Analysis: 'In-depth market analysis and technical insights.',
};
---

<BaseLayout
  title={`${category} Articles`}
  description={categoryDescriptions[category]}
>
  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6 sm:py-16">
    <div class="mb-10">
      <h1 class="mb-2 text-3xl font-extrabold tracking-tight sm:text-4xl">{category}</h1>
      <p class="text-lg text-text-secondary">{categoryDescriptions[category]}</p>
    </div>

    {filteredPosts.length > 0 ? (
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {filteredPosts.map((post) => (
          <ArticleCard
            title={post.data.title}
            date={post.data.date}
            category={post.data.category}
            summary={post.data.summary}
            slug={post.id}
            thumbnail={post.data.thumbnail}
          />
        ))}
      </div>
    ) : (
      <p class="text-center text-text-secondary">No articles in this category yet.</p>
    )}
  </section>
</BaseLayout>
